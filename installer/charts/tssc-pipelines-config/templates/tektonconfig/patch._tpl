{{- define "pipelines.TektonConfigPatch" -}}
  {{- $rekor_url := "" }}
  {{- $secretObj := (lookup "v1" "Secret" .Values.pipelines_config.integrationSecret.namespace "tssc-tas-integration") | default dict -}}
  {{- $secretData := (get $secretObj "data") | default dict -}}
  {{- if $secretData }}
    {{- $rekor_url = $secretData.rekor_url | b64dec }}
  {{- end }}
spec:
  chain:
    generateSigningSecret: true
    transparency.enabled: 'true'
    transparency.url: {{ $rekor_url }}
  platforms:
    openshift:
      pipelinesAsCode:
        settings:
          application-name: TSSC CI
          remember-ok-to-test: 'false'
  pruner:
    keep: 2
{{- end }}
